@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using System.Reflection
@using eProduccion.Data
@using eProduccion.Models
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject ConnectionService ConnectionService
@inject UserSession UserSession
@inject ProtectedLocalStorage SessionStorage

<div class="container-xxl position-relative bg-white d-flex p-0">

    @if (!sesionVerificada)
    {
        <!-- Spinner -->
        <div id="spinner"
             class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.subtitle1">Cargando...</MudText>
        </div>
    }
    else
    {
        <!-- MudBlazor Providers -->
        <MudThemeProvider />
        <MudPopoverProvider />
        <MudDialogProvider />
        <MudSnackbarProvider />

        <!-- Sidebar -->
        <NavMenu />

        <!-- Content -->
        <div class="content">
            <!-- Navbar -->
            <nav class="navbar navbar-expand bg-light navbar-light sticky-top px-4 py-0">
                <a href="index.html" class="navbar-brand d-flex d-lg-none me-4">
                    <h2 class="text-primary mb-0"><i class="fa fa-hashtag"></i></h2>
                </a>
                <a href="#" class="sidebar-toggler flex-shrink-0" @onclick:preventDefault>
                    <i class="fa fa-bars"></i>
                </a>
                <div class="navbar-nav align-items-center ms-auto">
                    <MudMenu Label="@UserSession.UserName" AnchorOrigin="Origin.TopRight" TransformOrigin="Origin.TopRight">
                        <MudMenuItem OnClick="CerrarSesion">Cerrar sesión</MudMenuItem>
                    </MudMenu>
                </div>
            </nav>

            <!-- Contenido dinámico -->
            <div class="container-fluid pt-4 px-4">
                <div class="row bg-light rounded mx-0 content-container">
                    @Body
                </div>
            </div>

            <!-- Footer -->
            <div class="container-fluid pt-4 px-4">
                <div class="bg-light rounded-top p-4">
                    <div class="row">
                        <div class="col-12 col-sm-6 text-center text-sm-start">
                            <MudText Typo="Typo.caption">@UserSession.DataBase</MudText>
                        </div>
                        <div class="col-12 col-sm-6 text-center text-sm-end">
                            <MudText Typo="Typo.caption">
                                Powered by EXXIS PY | @Assembly.GetExecutingAssembly().GetName().Version
                            </MudText>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>


@code {
    private bool _initialized = false;
    private bool sesionVerificada = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            await JS.InvokeVoidAsync("initializeSidebarToggle");

            var userResult = await SessionStorage.GetAsync<string>("UserName");
            var dbResult = await SessionStorage.GetAsync<string>("DataBase");
            var permisosResult = await SessionStorage.GetAsync<HashSet<string>>("Permisos");

            if (userResult.Success && dbResult.Success && permisosResult.Success)
            {
                UserSession.UserName = userResult.Value;
                UserSession.DataBase = dbResult.Value;
                UserSession.Permisos = permisosResult.Value;

                sesionVerificada = true;
                StateHasChanged();
            }
            else
            {
                NavigationManager.NavigateTo("/");
            }
        }
    }

    private async Task CerrarSesion()
    {
        // Cerrar sesión SAP
        ConnectionService.DisconnectSAP();
        // Limpiar sesión
        await SessionStorage.DeleteAsync("UserName");
        await SessionStorage.DeleteAsync("DataBase");
        await SessionStorage.DeleteAsync("Permisos");
        UserSession.Clear();
        // Redirigir al Login
        NavigationManager.NavigateTo("/");
    }
}