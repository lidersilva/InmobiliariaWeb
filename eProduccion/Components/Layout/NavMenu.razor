@using eProduccion.Components.Dialogs
@using eProduccion.Models
@using eProduccion.Security
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject UserSession UserSession

<!-- Sidebar Start -->
<div class="sidebar pe-4 pb-3">
    <nav class="navbar bg-light navbar-light">
        <a NavLink="#" class="navbar-brand mx-4 mb-3">
            <h3 class="text-primary">eProducción</h3>
        </a>
        <div class="navbar-nav w-100">
            <div class="nav-item dropdown">
                <a NavLink="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                    <i class="fa fa-wrench me-2"></i>Comercial
                </a>
                <div class="dropdown-menu bg-transparent border-0">
                    @if (UserSession.TienePermiso(PermisosSistema.PlanificacionOT))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/planificacionot")'>Planificación OT</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.Inyeccion))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/inyeccion")'>Inyección</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.Extrusion))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/extrusion")'>Extrusión</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.PlanificacionEnsamble))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/planificacionensamble")'>Planificación ensamble</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.Armado))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/armado")'>Armado</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.Flowpack))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/flowpack")'>Flowpack</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.Sachetera))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/sachetera")'>Sachetera</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.Sellado))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/sellado")'>Sellado</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.Horneado))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/horneado")'>Horneado</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.Empaquetado))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/empaquetado")'>Empaquetado</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.Prensa))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/prensa")'>Prensa</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.GrabadoLaser))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/grabado-laser")'>Grabado láser</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.PendienteMolinar))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/pendientemolinar")'>Pendiente a molinar</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.Molino))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/molino")'>Molino</a>
                    }
                </div>
            </div>

            @if (UserSession.TienePermiso(PermisosSistema.GestionAccesos))
            {
                <div class="nav-item dropdown">
                    <a NavLink="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                        <i class="fa fa-users me-2"></i>Gesti&oacute;n de Accesos
                    </a>
                    <div class="dropdown-menu bg-transparent border-0">
                        <a class="dropdown-item" @onclick='() => Navegar("/usuarios")'>Usuarios</a>
                        <a class="dropdown-item" @onclick='() => Navegar("/roles")'>Roles</a>
                        <a class="dropdown-item" @onclick='() => Navegar("/usuariosroles")'>Usuarios Roles</a>
                        <a class="dropdown-item" @onclick='() => Navegar("/permisos")'>Permisos</a>
                    </div>
                </div>
            }

            <div class="nav-item dropdown">
                <a NavLink="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                    <i class="fa fa-cogs me-2"></i>Configuraci&oacute;n
                </a>
                <div class="dropdown-menu bg-transparent border-0">
                    @if (UserSession.TienePermiso(PermisosSistema.GenerarEstructura))
                    {
                        <a class="dropdown-item" @onclick="AbrirModalEstructura">Crear estructura</a>
                    }
                    @if (UserSession.TienePermiso(PermisosSistema.Parametrizacion))
                    {
                        <a class="dropdown-item" @onclick='() => Navegar("/parametrizacion")'>Parametrizaci&oacute;n</a>
                    }
                </div>
            </div>
        </div>
    </nav>
</div>
<!-- Sidebar End -->
@code {
    private async Task AbrirModalEstructura()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };

        await DialogService.ShowAsync<EstructuraDialog>("Generar estructura", options);
    }

    private void Navegar(string ruta)
    {
        NavigationManager.NavigateTo(ruta);
    }
}