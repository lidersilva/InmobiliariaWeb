@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using eProduccion.Data.GestionAccesos
@using eProduccion.Data.Produccion
@using eProduccion.Models
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject InyeccionExtrusionService ExtrusionService
@inject UsuarioSistemaService UsuarioSistemaService
@inject ProtectedLocalStorage SessionStorage

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Class="mb-0">Carga Inyección</MudText>
    </TitleContent>
    <DialogContent>
        <MudTable T="OTInyeccionExtrusionDet" Items="@detallesExtrusion" Dense="true">
            <HeaderContent>
                <MudTh>Nro. contenedor</MudTh>
                <MudTh>Nro. máquina</MudTh>
                <MudTh>Fecha</MudTh>
                <MudTh>Hora inicio</MudTh>
                <MudTh>Hora fin</MudTh>
                <MudTh>Turno</MudTh>
                <MudTh>Operario</MudTh>
                <MudTh Class="text-nowrap">Operario 2</MudTh>
                <MudTh>Cant. aprobadas</MudTh>
                <MudTh>Cant. retenidas</MudTh>
                <MudTh>Cant. rechazadas reciclables</MudTh>
                <MudTh>Peso rechazado reciclable</MudTh>
                <MudTh Class="text-nowrap">Motivo rechazado reciclable</MudTh>
                <MudTh>Cant. rechazadas no reciclables</MudTh>
                <MudTh>Peso rechazado no reciclable</MudTh>
                <MudTh Class="text-nowrap">Motivo rechazado no reciclable</MudTh>
                <MudTh>Peso colada (KG)</MudTh>
                <MudTh>Peso masacote (KG)</MudTh>
                <MudTh>Peso por ajustes máq. (KG)</MudTh>
                <MudTh>Peso pieza (G)</MudTh>
                <MudTh>Cavidades reales</MudTh>
                <MudTh>Cavidades operativas</MudTh>
                <MudTh>Metros p/ min. real</MudTh>
                <MudTh>Metros p/ min.</MudTh>
                <MudTh>Metros p/ turno real</MudTh>
                <MudTh>Metros p/ turno</MudTh>
                <MudTh>Liberado producción</MudTh>
                <MudTh>DocNum salida</MudTh>
                <MudTh>Asiento</MudTh>
                <MudTh>DocNum entrada</MudTh>
                <MudTh>Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Nro. contenedor" Style="min-width: 110px;">
                    <MudTextField T="string" @bind-Value="@context.NroContenedor" Variant="Variant.Outlined" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Nro. máquina" Style="min-width: 110px;">
                    <MudTextField T="string" @bind-Value="@context.NroMaquina" Variant="Variant.Outlined" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Fecha" Style="min-width: 200px;">
                    <MudDatePicker T="DateTime?" @bind-Date="@context.Fecha" DateFormat="dd/MM/yyyy" Variant="Variant.Outlined" Margin="Margin.Dense" Class="w-100" Disabled="@(context.LineId > 0)" />
                </MudTd>
                <MudTd DataLabel="Hora inicio">@context.HoraInicio.ToString("HH:mm")</MudTd>
                <MudTd DataLabel="Hora fin">@context.HoraFin.ToString("HH:mm")</MudTd>
                <MudTd DataLabel="Turno" Style="min-width: 150px;">
                    <MudSelect T="string" @bind-Value="@context.Turno" Variant="Variant.Outlined" Margin="Margin.Dense" Class="w-100">
                        <MudSelectItem Value="@("TM")">TM - Mañana</MudSelectItem>
                        <MudSelectItem Value="@("TT")">TT - Tarde</MudSelectItem>
                        <MudSelectItem Value="@("TN")">TN - Noche</MudSelectItem>
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Operario" Style="min-width: 220px;">
                    <MudAutocomplete T="Usuario"
                                     SearchFunc="BuscarOperarios"
                                     ToStringFunc='operario => operario != null ? $"{operario.CodigoUsuario} {operario.NombreUsuario}" : string.Empty'
                                     @bind-Value="@context.UsuarioOperario"
                                     CoerceText="true"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     Dense="true" />
                </MudTd>
                <MudTd DataLabel="Operario 2" Style="min-width: 220px;">
                    <MudAutocomplete T="Usuario"
                                     SearchFunc="BuscarOperarios"
                                     ToStringFunc='operario => operario != null ? $"{operario.CodigoUsuario} {operario.NombreUsuario}" : string.Empty'
                                     @bind-Value="@context.UsuarioOperario2"
                                     CoerceText="true"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     Dense="true" />
                </MudTd>
                <MudTd DataLabel="Cant. aprobadas">
                    <MudNumericField T="int" @bind-Value="@context.CantAprobadas" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Cant. retenidas" Style="min-width: 110px;">
                    <MudNumericField T="int" @bind-Value="@context.CantRetenidas" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Cant. rechazadas reciclables" Style="min-width: 110px;">
                    <MudNumericField T="int" @bind-Value="@context.CantRechReciclable" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Peso rechazado reciclable" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.PesoRechReciclable" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Motivo rechazado reciclable" Style="min-width: 250px;">
                    <MudAutocomplete T="MotivoParadaDefecto"
                                     SearchFunc="BuscarMotivosDefectos"
                                     ToStringFunc='motivo => motivo != null ? $"{motivo.Codigo} {motivo.Descripcion}" : string.Empty'
                                     @bind-Value="@context.MotPesoRechReciclable"
                                     CoerceText="true"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     Dense="true" />
                </MudTd>
                <MudTd DataLabel="Cant. rechazadas no reciclables" Style="min-width: 110px;">
                    <MudNumericField T="int" @bind-Value="@context.CantRechNoReciclable" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Peso rechazado no reciclable" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.PesoRechNoReciclable" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Motivo rechazado no reciclable" Style="min-width: 250px;">
                    <MudAutocomplete T="MotivoParadaDefecto"
                                     SearchFunc="BuscarMotivosDefectos"
                                     ToStringFunc='motivo => motivo != null ? $"{motivo.Codigo} {motivo.Descripcion}" : string.Empty'
                                     @bind-Value="@context.MotPesoRechNoReciclable"
                                     CoerceText="true"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     Dense="true" />
                </MudTd>
                <MudTd DataLabel="Peso colada (KG)" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.PesoColadaKG" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Peso masacote (KG)" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.PesoMasacoteKG" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Peso por ajustes máq. (KG)" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.PesoAjusMaquinaKG" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Peso pieza (G)" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.PesoPiezaG" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Cavidades reales" Style="min-width: 110px;">
                    <MudNumericField T="int" @bind-Value="@context.CavidadReal" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" Disabled="true" />
                </MudTd>
                <MudTd DataLabel="Cavidades operativas" Style="min-width: 110px;">
                    <MudNumericField T="int" @bind-Value="@context.CavidadOperativa" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Metros p/ min. real" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.MetrosMinReal" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Metros p/ min." Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.MetrosMinuto" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Metros p/ turno real" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.MetrosTurnoReal" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Metros p/ turno" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.MetrosTurno" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Liberado producción"><input type="checkbox" class="form-check-input" @bind="context.Liberado"></MudTd>
                <MudTd DataLabel="DocNum salida">@context.DocNumSalida</MudTd>
                <MudTd DataLabel="Asiento">@context.Asiento</MudTd>
                <MudTd DataLabel="DocNum entrada">@context.DocNumEntrada</MudTd>
                <MudTd DataLabel="Acciones" Class="text-nowrap" Style="min-width: 160px;">
                    <MudTooltip Text="Guardar">
                        <MudIconButton Icon="@Icons.Material.Filled.Save" Variant="Variant.Filled" Color="Color.Info" Size="Size.Small" Class="mr-2" @onclick='() => GuardarLineaExtrusion(context)' Disabled="@(context.EstadoLinea == "Iniciado" || context.EstadoLinea == "Finalizado")" />
                    </MudTooltip>
                    <MudTooltip Text="Inicio">
                        <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="mr-2" @onclick='() => RegistrarInicio(context)' Disabled="@(context.LineId == 0 || context.EstadoLinea != "Pendiente")" />
                    </MudTooltip>
                    <MudTooltip Text="Parada">
                        <MudIconButton Icon="@Icons.Material.Filled.PauseCircle" Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" Class="mr-2" @onclick='() => AbrirModalParada(context)' Disabled="@(context.EstadoLinea != "Iniciado")" />
                    </MudTooltip>
                    <MudTooltip Text="Imprimir">
                        <MudIconButton Icon="@Icons.Material.Filled.Print" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small" Class="mr-2" Disabled="@(context.LineId == 0)" />
                    </MudTooltip>
                    <MudTooltip Text="Recibir">
                        <MudIconButton Icon="@Icons.Material.Filled.Check" Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" @onclick='() => AbrirModalRecibir(context)' Disabled="@(context.EstadoLinea != "Iniciado" || context.LineId == 0)" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager RowsPerPageString="Filas por página:" InfoFormat="{first_item}-{last_item} de {all_items}" AllItemsText="Todos" />
            </PagerContent>
        </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public OTInyeccionExtrusion OrdenExtrusion { get; set; }

    private List<Usuario> operarios;
    private Usuario operarioSeleccionado;
    private Usuario operario2Seleccionado;
    List<OTInyeccionExtrusionDet> detallesExtrusion = new();
    List<MotivoParadaDefecto> listaMotivoDefecto = new();
    OTInyeccionExtrusionDet nuevoDetalle = null;
    private string UserName = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var userResult = await SessionStorage.GetAsync<string>("UserName");
            if (userResult.Success)
                UserName = userResult.Value;

            listaMotivoDefecto = (await ExtrusionService.ObtenerMotivosParadaDefecto()).Where(x => x.Tipo == "DF").ToList();
            operarios = (await UsuarioSistemaService.ObtenerUsuarios()).Where(x => x.TipoUsuario == "OP").ToList();

            await CargarDetallesOTExtrusion();

            // Si no hay datos cargados, se agrega una línea vacía editable
            if (detallesExtrusion.Count == 0)
            {
                nuevoDetalle = new OTInyeccionExtrusionDet
                {
                    Fecha = DateTime.Today,
                    Turno = ObtenerTurnoSegunHoraSistema(),
                    CavidadReal = OrdenExtrusion.CavidadesReales,
                };

                detallesExtrusion.Add(nuevoDetalle);
            }
            else if (detallesExtrusion.LastOrDefault()?.EstadoLinea == "Finalizado")
            {
                var ultimaCarga = detallesExtrusion.Where(x => x.Operario == UserName && x.Turno == ObtenerTurnoSegunHoraSistema() && x.Fecha == DateTime.Today).LastOrDefault();

                nuevoDetalle = new OTInyeccionExtrusionDet
                {
                    Fecha = DateTime.Today,
                    Turno = ObtenerTurnoSegunHoraSistema(),
                    CavidadReal = OrdenExtrusion.CavidadesReales,
                };

                if (ultimaCarga != null)
                {
                    nuevoDetalle.PesoColadaKG = ultimaCarga.PesoColadaKG;
                    nuevoDetalle.PesoMasacoteKG = ultimaCarga.PesoMasacoteKG;
                    nuevoDetalle.PesoAjusMaquinaKG = ultimaCarga.PesoAjusMaquinaKG;
                    nuevoDetalle.PesoPiezaG = ultimaCarga.PesoPiezaG;
                    nuevoDetalle.CavidadOperativa = ultimaCarga.CavidadOperativa;
                    nuevoDetalle.MetrosMinReal = ultimaCarga.MetrosMinReal;
                    nuevoDetalle.MetrosMinuto = ultimaCarga.MetrosMinuto;
                    nuevoDetalle.MetrosTurnoReal = ultimaCarga.MetrosTurnoReal;
                    nuevoDetalle.MetrosTurno = ultimaCarga.MetrosTurno;
                }

                detallesExtrusion.Add(nuevoDetalle);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ha ocurrido un error: {ex.Message}", Severity.Error);
        }
    }

    private async Task GuardarLineaExtrusion(OTInyeccionExtrusionDet detalleExtrusion)
    {
        try
        {
            detalleExtrusion.MotiMPesoRechReciclable = detalleExtrusion.MotPesoRechReciclable?.Codigo;
            detalleExtrusion.MotiMPesoRechNoReciclable = detalleExtrusion.MotPesoRechNoReciclable?.Codigo;
            detalleExtrusion.Operario = detalleExtrusion.UsuarioOperario?.CodigoUsuario;
            detalleExtrusion.Operario2 = detalleExtrusion.UsuarioOperario2?.CodigoUsuario;

            await ExtrusionService.GuardarLineaInyeccionExtrusion(OrdenExtrusion.DocEntry, detalleExtrusion);

            await CargarDetallesOTExtrusion();

            StateHasChanged();

            Snackbar.Add($"Línea guardada correctamente", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ha ocurrido un error: {ex.Message}", Severity.Error);
        }
    }

    private async Task RegistrarInicio(OTInyeccionExtrusionDet detalleExtrusion)
    {
        try
        {
            await ExtrusionService.RegistrarInicioInyeccionExtrusion(OrdenExtrusion.DocEntry, detalleExtrusion);

            await CargarDetallesOTExtrusion();

            StateHasChanged();

            Snackbar.Add($"Línea iniciada correctamente", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ha ocurrido un error: {ex.Message}", Severity.Error);
        }
    }

    private async Task AbrirModalParada(OTInyeccionExtrusionDet detalleExtrusion)
    {
        var parameters = new DialogParameters
        {
            { "Estacion", "EXTRUSION" },
            { "DocEntryParam", detalleExtrusion.DocEntry },
            { "LineIdParam", detalleExtrusion.LineId },
            { "NroMaquinaParam", detalleExtrusion.NroMaquina },
            { "TurnoParam", detalleExtrusion.Turno },
            { "Operario", detalleExtrusion.Operario },
            { "Operario2", detalleExtrusion.Operario2 },
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = false,
            BackdropClick = false,
        };

        var dialog = await DialogService.ShowAsync<ParadaDialog>("", parameters, options);
    }

    private async Task AbrirModalRecibir(OTInyeccionExtrusionDet detalleExtrusion)
    {
        var parameters = new DialogParameters
        {
            { "MensajeFinalizar", $"¿Está seguro de proceder a Recibir/Emitir artículos?. Esto generará procesos de Emisión, Recibos y Asientos contables en SAP B1." },
            { "TextoBoton", "Recibir" }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true };

        var dialog = await DialogService.ShowAsync<FinalizarDialog>("Recibir artículos", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                detalleExtrusion.MotiMPesoRechReciclable = detalleExtrusion.MotPesoRechReciclable?.Codigo;
                detalleExtrusion.MotiMPesoRechNoReciclable = detalleExtrusion.MotPesoRechNoReciclable?.Codigo;
                detalleExtrusion.Operario = detalleExtrusion.UsuarioOperario?.CodigoUsuario;
                detalleExtrusion.Operario2 = detalleExtrusion.UsuarioOperario2?.CodigoUsuario;

                await ExtrusionService.FinalizarLineaInyeccionExtrusion(OrdenExtrusion.CodArticuloOV, OrdenExtrusion.CodArticuloIE, detalleExtrusion, "EXTRUSION");

                await CargarDetallesOTExtrusion();

                if (detallesExtrusion.LastOrDefault()?.EstadoLinea == "Finalizado")
                {
                    var ultimaCarga = detallesExtrusion.Where(x => x.Operario == UserName && x.Turno == ObtenerTurnoSegunHoraSistema() && x.Fecha == DateTime.Today).LastOrDefault();

                    nuevoDetalle = new OTInyeccionExtrusionDet
                    {
                        Fecha = DateTime.Today,
                        Turno = ObtenerTurnoSegunHoraSistema(),
                        CavidadReal = OrdenExtrusion.CavidadesReales,
                    };

                    if (ultimaCarga != null)
                    {
                        nuevoDetalle.PesoColadaKG = ultimaCarga.PesoColadaKG;
                        nuevoDetalle.PesoMasacoteKG = ultimaCarga.PesoMasacoteKG;
                        nuevoDetalle.PesoAjusMaquinaKG = ultimaCarga.PesoAjusMaquinaKG;
                        nuevoDetalle.PesoPiezaG = ultimaCarga.PesoPiezaG;
                        nuevoDetalle.CavidadOperativa = ultimaCarga.CavidadOperativa;
                        nuevoDetalle.MetrosMinReal = ultimaCarga.MetrosMinReal;
                        nuevoDetalle.MetrosMinuto = ultimaCarga.MetrosMinuto;
                        nuevoDetalle.MetrosTurnoReal = ultimaCarga.MetrosTurnoReal;
                        nuevoDetalle.MetrosTurno = ultimaCarga.MetrosTurno;
                    }

                    detallesExtrusion.Add(nuevoDetalle);
                }

                StateHasChanged();

                Snackbar.Add($"Documentos registrados en SAP correctamente", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Ha ocurrido un error: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task CargarDetallesOTExtrusion()
    {
        detallesExtrusion = await ExtrusionService.ObtenerDetalleInyeccionExtrusion(OrdenExtrusion.DocEntry);

        foreach (var det in detallesExtrusion)
        {
            det.MotPesoRechReciclable = listaMotivoDefecto.FirstOrDefault(x => x.Codigo == det.MotiMPesoRechReciclable);
            det.MotPesoRechNoReciclable = listaMotivoDefecto.FirstOrDefault(x => x.Codigo == det.MotiMPesoRechNoReciclable);
            det.UsuarioOperario = operarios.FirstOrDefault(x => x.CodigoUsuario == det.Operario);
            det.UsuarioOperario2 = operarios.FirstOrDefault(x => x.CodigoUsuario == det.Operario2);
        }
    }

    private string ObtenerTurnoSegunHoraSistema()
    {
        var horaActual = DateTime.Now.TimeOfDay;

        if (horaActual >= TimeSpan.FromHours(6) && horaActual < TimeSpan.FromHours(14))
            return "TM";
        if (horaActual >= TimeSpan.FromHours(14) && horaActual < TimeSpan.FromHours(22))
            return "TT";
        else
            return "TN";
    }

    private Task<IEnumerable<MotivoParadaDefecto>> BuscarMotivosDefectos(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(listaMotivoDefecto.AsEnumerable());

        var resultado = listaMotivoDefecto
            .Where(a =>
                (!string.IsNullOrEmpty(a.Codigo) && a.Codigo.Contains(value, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrEmpty(a.Descripcion) && a.Descripcion.Contains(value, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(a => a.Codigo)
            .Take(20);

        return Task.FromResult(resultado);
    }

    private Task<IEnumerable<Usuario>> BuscarOperarios(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(operarios.AsEnumerable());

        var resultado = operarios
            .Where(a =>
                (!string.IsNullOrEmpty(a.CodigoUsuario) && a.CodigoUsuario.Contains(value, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrEmpty(a.NombreUsuario) && a.NombreUsuario.Contains(value, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(a => a.CodigoUsuario)
            .Take(20);

        return Task.FromResult(resultado);
    }

    private void Cancel() => MudDialog.Cancel();
}
