@using eProduccion.Data.GestionAccesos
@using eProduccion.Data.Produccion
@using eProduccion.Models
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject EnsambleService EnsambleService
@inject UsuarioSistemaService UsuarioSistemaService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Class="mb-0">Registro Ensamble</MudText>
    </TitleContent>
    <DialogContent>
        <MudTable T="RegistroEnsambleDet" Items="@detallesRegEnsamble">
            <ToolBarContent>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@AgregarLinea">Agregar línea</MudButton>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Código</MudTh>
                <MudTh>Artículo</MudTh>
                <MudTh>Lote</MudTh>
                <MudTh>Tipo</MudTh>
                <MudTh>Cantidad</MudTh>
                <MudTh>Cant. reprocesado</MudTh>
                <MudTh>Operario</MudTh>
                <MudTh Class="text-nowrap">Operario 2</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Código" Style="min-width: 200px;">
                    @if (context.LineaNueva)
                    {
                        <MudTextField T="string" @bind-Value="@context.CodArticulo" Label="Artículo" ReadOnly="true" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search" Class="mud-width-full" Style="cursor: pointer;" @onclick='() => AbrirModalArticulo(context)' />
                    }
                    else
                    {
                        @context.CodArticulo
                    }
                </MudTd>
                <MudTd DataLabel="Artículo" Class="text-nowrap">@context.Articulo</MudTd>
                <MudTd DataLabel="Lote" Class="text-nowrap">
                    @if (context.LineaNueva)
                    {
                        <MudTextField T="string" @bind-Value="@context.Lote" Label="Lote" ReadOnly="true" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search" Class="mud-width-full" Style="cursor: pointer;" @onclick='() => AbrirModalLotes(context)' />
                    }
                    else
                    {
                        @context.Lote
                    }
                </MudTd>
                <MudTd DataLabel="Tipo" Style="min-width: 200px;">
                    @if (context.LineaNueva)
                    {
                        <MudSelect T="string" @bind-Value="@context.Tipo" Variant="Variant.Outlined" Margin="Margin.Dense" Class="w-100">
                            <MudSelectItem Value="@("DEVOLUCION")">DEVOLUCION</MudSelectItem>
                            <MudSelectItem Value="@("LIMPIEZA")">LIMPIEZA</MudSelectItem>
                            <MudSelectItem Value="@("RECHAZO")">RECHAZO</MudSelectItem>
                            <MudSelectItem Value="@("RECUPERACION")">RECUPERACION</MudSelectItem>
                            <MudSelectItem Value="@("RETENIDO")">RETENIDO</MudSelectItem>
                            <MudSelectItem Value="@("RETIRO")">RETIRO</MudSelectItem>
                        </MudSelect>
                    }
                    else
                    {
                        @context.Tipo
                    }
                </MudTd>
                <MudTd DataLabel="Cantidad">
                    @if (context.LineaNueva)
                    {
                        <MudTextField @bind-Value="@context.Cantidad" Inmediate="true" />
                    }
                    else
                    {
                        @context.Cantidad
                    }
                </MudTd>
                <MudTd DataLabel="Cant. reprocesado">
                    @if (context.LineaNueva)
                    {
                        <MudTextField @bind-Value="@context.CantidadReproceso" Inmediate="true" />
                    }
                    else
                    {
                        @context.CantidadReproceso
                    }
                </MudTd>
                <MudTd DataLabel="Operario" Style="min-width: 220px;">
                    @if (context.LineaNueva)
                    {
                        <MudAutocomplete T="Usuario"
                                         SearchFunc="BuscarOperarios"
                                         ToStringFunc='operario => operario != null ? $"{operario.CodigoUsuario} {operario.NombreUsuario}" : string.Empty'
                                         @bind-Value="@context.UsuarioOperario"
                                         CoerceText="true"
                                         Clearable="true"
                                         ResetValueOnEmptyText="true"
                                         Dense="true" />
                    }
                    else
                    {
                        @context.Operario
                    }
                </MudTd>
                <MudTd DataLabel="Operario 2" Style="min-width: 220px;">
                    @if (context.LineaNueva)
                    {
                        <MudAutocomplete T="Usuario"
                                         SearchFunc="BuscarOperarios"
                                         ToStringFunc='operario => operario != null ? $"{operario.CodigoUsuario} {operario.NombreUsuario}" : string.Empty'
                                         @bind-Value="@context.UsuarioOperario2"
                                         CoerceText="true"
                                         Clearable="true"
                                         ResetValueOnEmptyText="true"
                                         Dense="true" />
                    }
                    else
                    {
                        @context.Operario2
                    }
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager RowsPerPageString="Filas por página:" InfoFormat="{first_item}-{last_item} de {all_items}" AllItemsText="Todos" />
            </PagerContent>
        </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton @onclick="GuardarRegistroEnsamble">Guardar</MudButton>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public string Estacion { get; set; }
    [Parameter]
    public OTEnsamble OTEnsamble { get; set; }
    [Parameter]
    public OTEnsambleDet DetalleEnsamble { get; set; }

    List<RegistroEnsambleDet> detallesRegEnsamble = new();
    private List<Usuario> operarios;
    // private Usuario operarioSeleccionado;
    // private Usuario operario2Seleccionado;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            operarios = (await UsuarioSistemaService.ObtenerUsuarios()).Where(x => x.TipoUsuario == "OP").ToList();

            detallesRegEnsamble = await EnsambleService.ObtenerDetalleRegistroEnsamblado(DetalleEnsamble.DocEntry);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ha ocurrido un error: {ex.Message}", Severity.Error);
        }
    }

    private void AgregarLinea()
    {
        detallesRegEnsamble.Add(new RegistroEnsambleDet
        {
            CodArticulo = "",
            Articulo = "",
            Lote = "",
            Tipo = "",
            Cantidad = 0,
            LineaNueva = true,
        });
    }

    private async Task AbrirModalArticulo(RegistroEnsambleDet detalleRegistroEnsamble)
    {
        var parameters = new DialogParameters
        {
            { "Estacion", Estacion },
            { "CodePlanificacionOT", OTEnsamble.CodePlanificacionOT },
            { "CodSubArticulo", OTEnsamble.CodArticuloEnsamble },
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.False,
            BackdropClick = false,
        };

        var dialog = await DialogService.ShowAsync<ArticuloDialog>("", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is ListaMaterialesDet articuloSeleccionado)
        {
            detalleRegistroEnsamble.CodArticulo = articuloSeleccionado.Item;
            detalleRegistroEnsamble.Articulo = articuloSeleccionado.Descripcion;
        }
    }

    private async Task AbrirModalLotes(RegistroEnsambleDet detalleRegistroEnsamble)
    {
        var parameters = new DialogParameters
        {
            { "CodArticulo", detalleRegistroEnsamble.CodArticulo },
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.False,
            BackdropClick = false,
        };

        var dialog = await DialogService.ShowAsync<LoteDialog>("", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is Lote loteSeleccionado)
        {
            detalleRegistroEnsamble.Lote = loteSeleccionado.NroLote;
        }
    }

    private async Task GuardarRegistroEnsamble()
    {
        try
        {
            foreach (var detalle in detallesRegEnsamble)
            {
                detalle.Operario = detalle.UsuarioOperario?.CodigoUsuario;
                detalle.Operario2 = detalle.UsuarioOperario2?.CodigoUsuario;
            }

            await EnsambleService.GuardarRegistroEnsamblado(OTEnsamble.DocEntry, detallesRegEnsamble);

            detallesRegEnsamble = await EnsambleService.ObtenerDetalleRegistroEnsamblado(DetalleEnsamble.DocEntry);

            StateHasChanged();

            Snackbar.Add($"Registros guardados correctamente", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ha ocurrido un error: {ex.Message}", Severity.Error);
        }
    }

    private Task<IEnumerable<Usuario>> BuscarOperarios(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(operarios.AsEnumerable());

        var resultado = operarios
            .Where(a =>
                (!string.IsNullOrEmpty(a.CodigoUsuario) && a.CodigoUsuario.Contains(value, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrEmpty(a.NombreUsuario) && a.NombreUsuario.Contains(value, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(a => a.CodigoUsuario)
            .Take(20);

        return Task.FromResult(resultado);
    }

    private void Cancel() => MudDialog.Cancel();
}
