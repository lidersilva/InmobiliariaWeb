@using eProduccion.Data.Produccion
@using eProduccion.Models
@inject ISnackbar Snackbar
@inject InyeccionService InyeccionService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Class="mb-0">Registro paradas</MudText>
    </TitleContent>
    <DialogContent>
        <MudTable T="Parada" Items="@paradas">
            <HeaderContent>
                <MudTh>Nro. máquina</MudTh>
                <MudTh>Fecha</MudTh>
                <MudTh>Tipo paro</MudTh>
                <MudTh>Turno</MudTh>
                <MudTh>Hora inicio</MudTh>
                <MudTh>Hora fin</MudTh>
                <MudTh>Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Nro. máquina" Style="min-width: 110px;">
                    <MudTextField T="string" @bind-Value="@context.NroMaquina" Variant="Variant.Outlined" Class="w-100" Margin="Margin.Dense" Disabled="true" />
                </MudTd>
                <MudTd DataLabel="Fecha" Style="min-width: 200px;">
                    <MudDatePicker T="DateTime?" @bind-Date="@context.Fecha" DateFormat="dd/MM/yyyy" Variant="Variant.Outlined" Margin="Margin.Dense" Class="w-100" Disabled="true" />
                </MudTd>
                <MudTd DataLabel="Tipo paro" Style="min-width: 110px;">
                    <MudTextField T="string" @bind-Value="@context.TipoParada" Variant="Variant.Outlined" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Turno" Style="min-width: 150px;">
                    <MudSelect T="string" @bind-Value="@context.Turno" Variant="Variant.Outlined" Margin="Margin.Dense" Class="w-100" Disabled="true">
                        <MudSelectItem Value="@("TM")">TM - Mañana</MudSelectItem>
                        <MudSelectItem Value="@("TT")">TT - Tarde</MudSelectItem>
                        <MudSelectItem Value="@("TN")">TN - Noche</MudSelectItem>
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Hora inicio">@context.HoraInicio.ToString("HH:mm")</MudTd>
                <MudTd DataLabel="Hora fin">@context.HoraFin.ToString("HH:mm")</MudTd>
                <MudTd DataLabel="Acciones" Class="text-nowrap" Style="min-width: 160px;">
                    <MudTooltip Text="@(context.DocEntry == 0 ? "Iniciar" : "Detener")">
                        <MudIconButton Icon="@(context.DocEntry == 0 ? Icons.Material.Filled.PlayArrow : Icons.Material.Filled.Stop)" Variant="Variant.Filled"
                                       Color="@(context.DocEntry == 0 ? Color.Primary : Color.Error)" Size="Size.Small" Class="mr-2" Disabled="@(context.Estado == "Detenido")"
                                       @onclick='() => RegistrarParada(context)' />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager RowsPerPageString="Filas por página:" InfoFormat="{first_item}-{last_item} de {all_items}" AllItemsText="Todos" />
            </PagerContent>
        </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public OTInyeccionDet DetalleInyeccion { get; set; }

    List<Parada> paradas = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            paradas = await InyeccionService.ObtenerRegistroParadas(DetalleInyeccion.DocEntry, DetalleInyeccion.LineId, "INYECCION");

            // Si no hay datos cargados, se agrega una línea vacía editable
            if (paradas.Count == 0 || paradas.LastOrDefault()?.Estado == "Detenido")
            {
                paradas.Add(new Parada
                {
                    NroMaquina = DetalleInyeccion.NroMaquina,
                    Fecha = DateTime.Today,
                    Turno = DetalleInyeccion.Turno,
                });
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ha ocurrido un error: {ex.Message}", Severity.Error);
        }
    }

    private async Task RegistrarParada(Parada parada)
    {
        try
        {
            await InyeccionService.RegistrarParada(parada, DetalleInyeccion);

            paradas = await InyeccionService.ObtenerRegistroParadas(DetalleInyeccion.DocEntry, DetalleInyeccion.LineId, "INYECCION");

            if (paradas.LastOrDefault()?.Estado == "Detenido")
            {
                paradas.Add(new Parada
                {
                    NroMaquina = DetalleInyeccion.NroMaquina,
                    Fecha = DateTime.Today,
                    Turno = DetalleInyeccion.Turno,
                });
            }

            StateHasChanged();

            Snackbar.Add($"Parada registrada correctamente", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ha ocurrido un error: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
