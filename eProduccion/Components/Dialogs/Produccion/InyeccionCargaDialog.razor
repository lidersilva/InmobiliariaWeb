@using eProduccion.Data.Produccion
@using eProduccion.Models
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject InyeccionService InyeccionService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Class="mb-0">Carga Inyección</MudText>
    </TitleContent>
    <DialogContent>
        <MudTable T="OTInyeccionDet" Items="@detallesInyeccion">
            <HeaderContent>
                <MudTh>Nro. contenedor</MudTh>
                <MudTh>Nro. máquina</MudTh>
                <MudTh>Fecha</MudTh>
                <MudTh>Hora inicio</MudTh>
                <MudTh>Hora fin</MudTh>
                <MudTh>Turno</MudTh>
                <MudTh>Operario</MudTh>
                <MudTh>Cant. aprobadas</MudTh>
                <MudTh>Cant. retenidas</MudTh>
                <MudTh>Cant. rechazadas reciclables</MudTh>
                <MudTh>Peso rechazado reciclable</MudTh>
                <MudTh>Motivo rechazado reciclable</MudTh>
                <MudTh>Cant. rechazadas no reciclables</MudTh>
                <MudTh>Peso rechazado no reciclable</MudTh>
                <MudTh>Motivo rechazado no reciclable</MudTh>
                <MudTh>Peso colada (KG)</MudTh>
                <MudTh>Peso masacote (KG)</MudTh>
                <MudTh>Peso por ajustes máq. (KG)</MudTh>
                <MudTh>Peso pieza (G)</MudTh>
                <MudTh>Cavidades reales</MudTh>
                <MudTh>Cavidades operativas</MudTh>
                <MudTh>Tiempo ciclo (S)</MudTh>
                <MudTh>Tiempo ciclo real (S)</MudTh>
                <MudTh>Liberado producción</MudTh>
                <MudTh>DocNum entrada</MudTh>
                <MudTh>DocNum salida</MudTh>
                <MudTh>Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Nro. contenedor" Style="min-width: 110px;">
                    <MudTextField T="string" @bind-Value="@context.NroContenedor" Variant="Variant.Outlined" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Nro. máquina" Style="min-width: 110px;">
                    <MudTextField T="string" @bind-Value="@context.NroMaquina" Variant="Variant.Outlined" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Fecha" Style="min-width: 200px;">
                    <MudDatePicker T="DateTime?" @bind-Date="@context.Fecha" DateFormat="dd/MM/yyyy" Variant="Variant.Outlined" Margin="Margin.Dense" Class="w-100" Disabled="@(context.LineId > 0)" />
                </MudTd>
                <MudTd DataLabel="Hora inicio">@context.HoraInicio.ToString("HH:mm")</MudTd>
                <MudTd DataLabel="Hora fin">@context.HoraFin.ToString("HH:mm")</MudTd>
                <MudTd DataLabel="Turno" Style="min-width: 150px;">
                    <MudSelect T="string" @bind-Value="@context.Turno" Variant="Variant.Outlined" Margin="Margin.Dense" Class="w-100">
                        <MudSelectItem Value="@("TM")">TM - Mañana</MudSelectItem>
                        <MudSelectItem Value="@("TT")">TT - Tarde</MudSelectItem>
                        <MudSelectItem Value="@("TN")">TN - Noche</MudSelectItem>
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Operario"></MudTd>
                <MudTd DataLabel="Cant. aprobadas">
                    <MudNumericField T="int" @bind-Value="@context.CantAprobadas" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Cant. retenidas" Style="min-width: 110px;">
                    <MudNumericField T="int" @bind-Value="@context.CantRetenidas" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Cant. rechazadas reciclables" Style="min-width: 110px;">
                    <MudNumericField T="int" @bind-Value="@context.CantRechReciclable" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Peso rechazado reciclable" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.PesoRechReciclable" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Motivo rechazado reciclable"></MudTd>
                <MudTd DataLabel="Cant. rechazadas no reciclables" Style="min-width: 110px;">
                    <MudNumericField T="int" @bind-Value="@context.CantRechNoReciclable" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Peso rechazado no reciclable" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.PesoRechNoReciclable" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Motivo rechazado no reciclable" Style="min-width: 110px;"></MudTd>
                <MudTd DataLabel="Peso colada (KG)" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.PesoColadaKG" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Peso masacote (KG)" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.PesoMasacoteKG" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Peso por ajustes máq. (KG)" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.PesoAjusMaquinaKG" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Peso pieza (G)" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.PesoPiezaG" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Cavidades reales" Style="min-width: 110px;">
                    <MudNumericField T="int" @bind-Value="@context.CavidadReal" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Cavidades operativas" Style="min-width: 110px;">
                    <MudNumericField T="int" @bind-Value="@context.CavidadOperativa" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Tiempo ciclo (S)" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.TiempoCiclo" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Tiempo ciclo real (S)" Style="min-width: 110px;">
                    <MudNumericField T="double" @bind-Value="@context.TiempoCicloReal" Min="0" Immediate="true" Variant="Variant.Outlined" HideSpinButtons="true" Class="w-100" Margin="Margin.Dense" />
                </MudTd>
                <MudTd DataLabel="Liberado producción"><input type="checkbox" class="form-check-input" @bind="context.Liberado"></MudTd>
                <MudTd DataLabel="DocNum entrada">@context.DocNumEntrada</MudTd>
                <MudTd DataLabel="DocNum salida">@context.DocNumSalida</MudTd>
                <MudTd DataLabel="Acciones" Class="text-nowrap" Style="min-width: 160px;">
                    <MudTooltip Text="Guardar">
                        <MudIconButton Icon="@Icons.Material.Filled.Save" Variant="Variant.Filled" Color="Color.Info" Size="Size.Small" Class="mr-2" @onclick='() => GuardarLineaInyeccion(context)' Disabled="@(context.EstadoLinea == "Iniciado" || context.EstadoLinea == "Finalizado")" />
                    </MudTooltip>
                    <MudTooltip Text="Inicio">
                        <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="mr-2" @onclick='() => RegistrarInicio(context)' Disabled="@(context.LineId == 0 || context.EstadoLinea != "Pendiente")" />
                    </MudTooltip>
                    <MudTooltip Text="Parada">
                        <MudIconButton Icon="@Icons.Material.Filled.PauseCircle" Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" Class="mr-2" @onclick='() => AbrirModalParada(context)' Disabled="@(context.EstadoLinea != "Iniciado")" />
                    </MudTooltip>
                    <MudTooltip Text="Imprimir">
                        <MudIconButton Icon="@Icons.Material.Filled.Print" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small" Class="mr-2" Disabled="@(context.LineId == 0)" />
                    </MudTooltip>
                    <MudTooltip Text="Recibir">
                        <MudIconButton Icon="@Icons.Material.Filled.Check" Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" @onclick='() => AbrirModalRecibir(context)' Disabled="@(context.EstadoLinea != "Iniciado" || context.LineId == 0)" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager RowsPerPageString="Filas por página:" InfoFormat="{first_item}-{last_item} de {all_items}" AllItemsText="Todos" />
            </PagerContent>
        </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public OTInyeccion OrdenInyeccion { get; set; }

    List<OTInyeccionDet> detallesInyeccion = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            detallesInyeccion = await InyeccionService.ObtenerDetalleInyeccion(OrdenInyeccion.DocEntry);

            // Si no hay datos cargados, se agrega una línea vacía editable
            if (detallesInyeccion.Count == 0 || detallesInyeccion.LastOrDefault()?.EstadoLinea == "Finalizado")
            {
                detallesInyeccion.Add(new OTInyeccionDet
                {
                    Fecha = DateTime.Today,
                });
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ha ocurrido un error: {ex.Message}", Severity.Error);
        }
    }

    private async Task GuardarLineaInyeccion(OTInyeccionDet detalleInyeccion)
    {
        try
        {
            await InyeccionService.GuardarLineaInyeccion(OrdenInyeccion.DocEntry, detalleInyeccion);

            detallesInyeccion = await InyeccionService.ObtenerDetalleInyeccion(OrdenInyeccion.DocEntry);

            StateHasChanged();

            Snackbar.Add($"Línea guardada correctamente", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ha ocurrido un error: {ex.Message}", Severity.Error);
        }
    }

    private async Task RegistrarInicio(OTInyeccionDet detalleInyeccion)
    {
        try
        {
            await InyeccionService.RegistrarInicioInyeccion(OrdenInyeccion.DocEntry, detalleInyeccion);

            detallesInyeccion = await InyeccionService.ObtenerDetalleInyeccion(OrdenInyeccion.DocEntry);

            StateHasChanged();

            Snackbar.Add($"Línea iniciada correctamente", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ha ocurrido un error: {ex.Message}", Severity.Error);
        }
    }

    private async Task AbrirModalParada(OTInyeccionDet detalleInyeccion)
    {
        var parameters = new DialogParameters
        {
            { "DetalleInyeccion", detalleInyeccion },
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = false,
            BackdropClick = false,
        };

        var dialog = await DialogService.ShowAsync<ParadaDialog>("", parameters, options);
    }

    private async Task AbrirModalRecibir(OTInyeccionDet detalleInyeccion)
    {
        var parameters = new DialogParameters
        {
            { "MensajeFinalizar", $"¿Está seguro de proceder a Recibir/Emitir artículos?. Esto generará procesos de Emisión, Recibos y Asientos contables en SAP B1." },
            { "TextoBoton", "Recibir" }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true };

        var dialog = await DialogService.ShowAsync<FinalizarDialog>("Recibir artículos", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                await InyeccionService.FinalizarLineaInyeccion(OrdenInyeccion.CodArticuloOV, OrdenInyeccion.CodArticuloI, detalleInyeccion);

                detallesInyeccion = await InyeccionService.ObtenerDetalleInyeccion(OrdenInyeccion.DocEntry);

                if (detallesInyeccion.LastOrDefault()?.EstadoLinea == "Finalizado")
                {
                    detallesInyeccion.Add(new OTInyeccionDet
                    {
                        Fecha = DateTime.Today,
                    });
                }

                StateHasChanged();

                Snackbar.Add($"Salida de mercancías generada correctamente", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Ha ocurrido un error: {ex.Message}", Severity.Error);
            }
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
