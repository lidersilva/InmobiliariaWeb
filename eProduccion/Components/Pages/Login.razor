@page "/"
@rendermode InteractiveServer
@layout Components.Layout.EmptyLayout
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using System.Reflection
@using System.Text.Json;
@using eProduccion.Models
@using eProduccion.Data
@inject NavigationManager NavigationManager
@inject ProtectedLocalStorage SessionStorage
@inject ConnectionService ConnectionService

<div class="container-xxl position-relative bg-white d-flex p-0">
    <!-- Sign In Start -->
    <div class="container-fluid">
        <div class="row h-100 align-items-center justify-content-center" style="min-height: 100vh;">
            <div class="col-12 col-sm-8 col-md-6 col-lg-5 col-xl-4">
                <div class="bg-light rounded p-4 p-sm-5 my-4 mx-3">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h3 class="text-primary">Emsa Inmobiliaria</h3>
                    </div>
                    <div class="form-floating mb-3">
                        <select class="form-select" @bind="BaseDatos">
                            @foreach (var db in BaseDatosJson)
                            {
                                <option value="@db.NombreBaseDatos">@db.NombreBaseDatos</option>
                            }
                        </select>
                        <label>Base de Datos</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="text" @bind="Usuario" class="form-control" placeholder="Usuario">
                        <label>Usuario</label>
                    </div>
                    <div class="form-floating mb-4">
                        <input type="password" @bind="Password" class="form-control" placeholder="Contrase&ncaron;a">
                        <label>Contrase&ncaron;a</label>
                    </div>
                    <button class="btn btn-primary py-3 w-100 mb-4" @onclick="IniciarSesion">Login</button>

                    <p class="text-muted text-center">Versi&oacute;n @Assembly.GetExecutingAssembly().GetName().Version.ToString()</p>

                    @if (!string.IsNullOrEmpty(mensajeError))
                    {
                        <div class="alert alert-danger" role="alert">
                            @mensajeError
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
    <!-- Sign In End -->
</div>

@code {
    private List<BaseDatos> BaseDatosJson = new();
    private string Usuario = "";
    private string Password = "";
    private string BaseDatos = "";
    private string mensajeError = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var ruta = Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "databases.json");
            var json = await File.ReadAllTextAsync(ruta);
            var datos = JsonSerializer.Deserialize<List<BaseDatos>>(json);

            if (datos is not null)
            {
                BaseDatosJson = datos;
                BaseDatos = BaseDatosJson.FirstOrDefault()?.NombreBaseDatos ?? "";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error cargando bases de datos: {ex.Message}";
        }
    }

    private async Task IniciarSesion()
    {
        mensajeError = "";

        try
        {
            // Realiza la conexión en segundo plano
            await ConnectionService.ConnectSAP(Usuario, Password, BaseDatos);

            // Guarda los datos de sesión de forma segura
            await SessionStorage.SetAsync("UserName", Usuario);
            await SessionStorage.SetAsync("DataBase", BaseDatos);

            NavigationManager.NavigateTo("/home");
        }
        catch (Exception ex)
        {
            mensajeError = ex.Message;
        }
    }
}
