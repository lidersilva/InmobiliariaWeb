@page "/armado"
@using eProduccion.Components.Dialogs.Produccion
@using eProduccion.Models
@using eProduccion.Utility
@using eProduccion.Data.Produccion
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject EnsambleService EnsambleService

<PageTitle>eProducci&oacute;n | Armado</PageTitle>

<div class="row">
    <div class="col-12">
        <div class="p-4">
            <div class="table-responsive">
                <MudTable Items="@listaArmado" Filter="FiltrarTabla" Class="w-100">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">Armado</MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="textoBusqueda" Placeholder="Buscar" Immediate="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh>OT</MudTh>
                        <MudTh>Fecha OT</MudTh>
                        <MudTh>DocNum OV</MudTh>
                        <MudTh>Serie OV</MudTh>
                        <MudTh>Código OT</MudTh>
                        <MudTh>Artículo OT</MudTh>
                        <MudTh>Acciones</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="OT">@context.DocEntry</MudTd>
                        <MudTd DataLabel="Fecha OT">@context.FechaOT.ToString("dd/MM/yyyy")</MudTd>
                        <MudTd DataLabel="DocNum OV">@context.DocNumOV</MudTd>
                        <MudTd DataLabel="Serie OV">@context.SerieOV</MudTd>
                        <MudTd DataLabel="Código OT" Class="text-nowrap">@context.CodArticuloEnsamble</MudTd>
                        <MudTd DataLabel="Artículo OT" Class="text-nowrap">@context.ArticuloEnsamble</MudTd>
                        <MudTd DataLabel="Acciones" Class="text-nowrap" Style="min-width: 160px;">
                            <MudTooltip Text="Cargar">
                                <MudIconButton Icon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
                            </MudTooltip>
                            <MudTooltip Text="Cancelar">
                                <MudIconButton Icon="@Icons.Material.Filled.Cancel" Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" Class="mr-2" />
                            </MudTooltip>
                            <MudTooltip Text="Finalizar">
                                <MudIconButton Icon="@Icons.Material.Filled.Check" Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager RowsPerPageString="Filas por página:" InfoFormat="{first_item}-{last_item} de {all_items}" AllItemsText="Todos" />
                    </PagerContent>
                </MudTable>
            </div>
        </div>
    </div>
</div>

@code {
    private List<OTEnsamble> listaArmado;
    private string textoBusqueda = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            listaArmado = await EnsambleService.ObtenerOTEnsamblado("ARMADO");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ha ocurrido un error: {ex.Message}", Severity.Error);
        }
    }

    private bool FiltrarTabla(OTEnsamble item) => AplicarFiltroTabla(item, textoBusqueda);

    private bool AplicarFiltroTabla(OTEnsamble item, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;

        searchString = searchString.Trim().ToLower();

        return
            item.DocEntry.ToString().Contains(searchString) ||
            item.FechaOT.ToString("dd/MM/yyyy").Contains(searchString) ||
            (!string.IsNullOrWhiteSpace(item.CodArticuloOV) && item.CodArticuloOV.ToLower().Contains(searchString)) ||
            (!string.IsNullOrWhiteSpace(item.ArticuloOV) && item.ArticuloOV.ToLower().Contains(searchString)) ||
            (!string.IsNullOrWhiteSpace(item.CodArticuloEnsamble) && item.CodArticuloEnsamble.ToLower().Contains(searchString)) ||
            (!string.IsNullOrWhiteSpace(item.ArticuloEnsamble) && item.ArticuloEnsamble.ToLower().Contains(searchString)) ||
            item.DocNumOV.ToString().Contains(searchString) ||
            (!string.IsNullOrWhiteSpace(item.SerieOV) && item.SerieOV.ToLower().Contains(searchString)) ||
            (!string.IsNullOrWhiteSpace(item.EstadoOT) && item.EstadoOT.ToLower().Contains(searchString));
    }
}
