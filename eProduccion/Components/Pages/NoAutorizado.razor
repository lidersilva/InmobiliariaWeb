@page "/no-autorizado"

<PageTitle>Acceso denegado</PageTitle>

<div class="container-fluid d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="text-center">
        <i class="fa fa-lock fa-4x text-danger mb-3"></i>

        <h3 class="mb-2">Acceso no autorizado</h3>
        <p class="text-muted mb-4">
            No tiene permisos para acceder a esta ventana.
        </p>

        <button class="btn btn-primary" @onclick="Volver">
            Volver al inicio
        </button>
    </div>
</div>

@code {
    [Inject] NavigationManager Navigation { get; set; }

    private void Volver()
    {
        Navigation.NavigateTo("/home");
    }
}
